# Airflow configuration
# Set AIRFLOW_HOME to the airflow directory:
# export AIRFLOW_HOME=$(pwd)/airflow
# 
# Or run from the airflow directory:
# cd airflow && uv run python dags/ingest_products.py

# OpenAI key used by the CLI agent (replace placeholder with your actual key).
OPENAI_API_KEY=<enter your openai api key>
